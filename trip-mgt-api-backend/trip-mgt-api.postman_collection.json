{
  "info": {
    "name": "Trip Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "guestId", "value": "1" },
    { "key": "tripId", "value": "101" }
  ],
  "item": [
    {
      "name": "List Trips",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/guests/{{guestId}}/trips",
          "host": ["{{baseUrl}}"],
          "path": ["guests", "{{guestId}}", "trips"]
        }
      }
    },
    {
      "name": "List Trips (filter by name)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/guests/{{guestId}}/trips?tripName=Summer",
          "host": ["{{baseUrl}}"],
          "path": ["guests", "{{guestId}}", "trips"],
          "query": [{ "key": "tripName", "value": "Summer" }]
        }
      }
    },
    {
      "name": "Create Trip",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/guests/{{guestId}}/trips",
          "host": ["{{baseUrl}}"],
          "path": ["guests", "{{guestId}}", "trips"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Holiday Retreat\",\n  \"startDate\": \"2025-12-20\",\n  \"endDate\": \"2025-12-27\"\n}"
        }
      }
    },
    {
      "name": "Get Trip by ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/guests/{{guestId}}/trips/{{tripId}}",
          "host": ["{{baseUrl}}"],
          "path": ["guests", "{{guestId}}", "trips", "{{tripId}}"]
        }
      }
    },
    {
      "name": "Update Trip",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/guests/{{guestId}}/trips/{{tripId}}",
          "host": ["{{baseUrl}}"],
          "path": ["guests", "{{guestId}}", "trips", "{{tripId}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Summer Vacation (Updated)\",\n  \"startDate\": \"2025-07-05\",\n  \"endDate\": \"2025-07-15\"\n}"
        }
      }
    },
    {
      "name": "Delete Trip",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/guests/{{guestId}}/trips/{{tripId}}",
          "host": ["{{baseUrl}}"],
          "path": ["guests", "{{guestId}}", "trips", "{{tripId}}"]
        }
      }
    }
  ]
}
