{
  "info": {
    "name": "Trip Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "guestId",
      "value": "1"
    },
    {
      "key": "tripId",
      "value": "101",
      "description": "Guest 1: 101-102 | Guest 2: 201-202 | Guest 3: 301-302 | Guest 4: 401-402 | Guest 5: 501-502"
    }
  ],
  "item": [
    {
      "name": "List Trips",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/guests/{{guestId}}/trips"
      }
    },
    {
      "name": "Get Trip",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/guests/{{guestId}}/trips/{{tripId}}"
      }
    },
    {
      "name": "Create Trip",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/guests/{{guestId}}/trips",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"New Trip\",\n  \"startDate\": \"2026-05-01\",\n  \"endDate\": \"2026-05-05\"\n}"
        }
      }
    },
    {
      "name": "Update Trip",
      "request": {
        "method": "PUT",
        "url": "{{baseUrl}}/guests/{{guestId}}/trips/{{tripId}}",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Updated Trip\",\n  \"startDate\": \"2026-05-01\",\n  \"endDate\": \"2026-05-10\"\n}"
        }
      }
    },
    {
      "name": "Delete Trip",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/guests/{{guestId}}/trips/{{tripId}}"
      }
    }
  ]
}
